# =============================================================================
# Auto Cost Engine — Backup Cron Container
# =============================================================================
# Runs backup-db.sh on a schedule (default: daily at 2 AM).
# Backups are uploaded to MinIO with automatic retention policies.
# =============================================================================

FROM alpine:3.19@sha256:6baf43584bcb78f2e5847d1de515f23499913ac9f12bdf834811a3145eb11ca1

RUN apk add --no-cache \
    bash \
    curl \
    postgresql-client \
    && rm -rf /var/cache/apk/*

# Install MinIO client (mc)
RUN curl -fsSL https://dl.min.io/client/mc/release/linux-amd64/mc \
    -o /usr/local/bin/mc && \
    chmod +x /usr/local/bin/mc

# Copy the backup script
COPY backup-db.sh /usr/local/bin/backup-db.sh
RUN chmod +x /usr/local/bin/backup-db.sh

# Create cron job: run backup daily at 2 AM
RUN mkdir -p /etc/periodic/daily
COPY backup-cron /etc/crontabs/root

# Run crond in foreground
CMD ["crond", "-f", "-l", "2"]
