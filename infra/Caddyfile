# Auto Cost Engine — Production Caddyfile with TLS + Security Headers
#
# This configuration is designed for production deployment behind a
# public domain name.  It provides:
#
#   - Automatic TLS via Let's Encrypt (requires a public DNS record)
#   - TLS 1.3 only (drops older, weaker protocols)
#   - Security headers (CSP, HSTS, X-Frame-Options, etc.)
#   - Structured JSON access logs
#   - Per-path reverse-proxy routing (API → backend, Auth → Keycloak,
#     everything else → frontend)
#
# For local development use ``infra/Caddyfile.dev`` instead.

*.example.com {
    # ---- TLS (Let's Encrypt automatic) ----
    # Replace *.example.com with your actual domain (or use a specific
    # hostname like ``app.example.com``).  Caddy automatically provisions
    # and renews certificates via the ACME protocol.
    tls {
        protocols tls1.3
    }

    # ---- Security headers ----
    # These headers are added to every response.  They are the standard
    # OWASP-recommended set for hardening web applications.
    header {
        # Prevent MIME-type sniffing
        X-Content-Type-Options "nosniff"
        # Disallow rendering in <frame>/<iframe> (clickjacking protection)
        X-Frame-Options "DENY"
        # Enable XSS filter in older browsers
        X-XSS-Protection "1; mode=block"
        # Control how much referrer info is leaked
        Referrer-Policy "strict-origin-when-cross-origin"
        # Restrict which browser features / APIs can be used
        Permissions-Policy "geolocation=(), camera=(), microphone=()"
        # Content Security Policy — adjust as needed for your assets
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:;"
        # HTTP Strict Transport Security (preload-ready after testing)
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    }

    # ---- API requests → backend ----
    handle_path /api/* {
        reverse_proxy backend:8000
    }

    # ---- Auth requests → Keycloak ----
    handle_path /auth/* {
        reverse_proxy keycloak:8080
    }

    # ---- Everything else → frontend ----
    handle {
        reverse_proxy frontend:5173
    }

    # ---- Structured access logs ----
    log {
        output file /var/log/caddy/access.log
        format json
    }
}

# ---- HTTP→HTTPS redirect (for development / staging) ----
# When running behind a local reverse proxy or during staging you can
# keep this block to redirect plain HTTP traffic to HTTPS.
localhost:80 {
    redir https://{host}{uri}
}
