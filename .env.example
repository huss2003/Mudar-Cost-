# ═══════════════════════════════════════════════════════════════════════════════
# Auto Cost Engine  —  Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in every value before starting the stack.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
# Application name (cosmetic, used in logging / API metadata)
APP_NAME=
# Runtime environment.  One of: production, staging, dev
ENVIRONMENT=
# Enable debug mode (verbose logging / dev error pages).  Keep False in prod.
DEBUG=
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=
# Django/FastAPI-style secret key used for signing tokens, sessions, etc.
# Must be at least 32 characters.  Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# ── Database (PostgreSQL + asyncpg) ──────────────────────────────────────────
# Full connection string.  Example:
#   postgresql+asyncpg://estimation:<password>@postgres:5432/estimation
DATABASE_URL=

# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
# Host and port of the MinIO server, e.g. minio:9000
MINIO_ENDPOINT=
# Access key / user name for the MinIO admin or service account
MINIO_ACCESS_KEY=
# Secret key / password for the above account
MINIO_SECRET_KEY=
# Bucket name where drawings and exports are stored
MINIO_BUCKET=

# ── Redis ────────────────────────────────────────────────────────────────────
# Redis connection string used by the app (caching, rate limiting)
REDIS_URL=
# Celery broker URL (typically a different Redis DB)
CELERY_BROKER_URL=
# Celery result backend URL
CELERY_RESULT_BACKEND=

# ── Keycloak (OpenID Connect) ────────────────────────────────────────────────
# Keycloak server base URL, e.g. http://keycloak:8080
KEYCLOAK_URL=
# Keycloak realm name (must exist and be configured for the client below)
KEYCLOAK_REALM=
# OIDC client ID that the backend uses for token exchange
KEYCLOAK_CLIENT_ID=
# OIDC client secret (confidential client)
KEYCLOAK_CLIENT_SECRET=

# ── AI / LLM APIs — MiMo v2.5 for everything (vision + text) ────────────────
# MiMo API key.  Required when ENVIRONMENT=production.  Get from https://mimo.mi.com
MIMO_API_KEY=
# MiMo API base URL (override for custom endpoints). Default: https://api.xiaomimimo.com/v1
MIMO_API_BASE=
# DeepSeek endpoint aliased to MiMo (MiMo v2.5 handles text too)
DEEPSEEK_API_KEY=
# DeepSeek API base URL. Default: https://api.xiaomimimo.com/v1 (same as MiMo)
DEEPSEEK_API_BASE=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  Example:
#   http://localhost:5173,http://localhost:3000,https://app.example.com
CORS_ORIGINS=

# ── Upload Limits ─────────────────────────────────────────────────────────────
# Maximum upload size in megabytes for drawing files
MAX_UPLOAD_MB=

# ── PostgreSQL (Docker) ──────────────────────────────────────────────────────
# These are consumed by docker-compose.yml, not by the Python backend.
# They control the container-level credentials.
POSTGRES_PASSWORD=

# ── MinIO (Docker) ───────────────────────────────────────────────────────────
# These are consumed by docker-compose.yml, not by the Python backend.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ── Keycloak Admin (Docker) ──────────────────────────────────────────────────
# Consumed by docker-compose.yml for Keycloak bootstrap.
KEYCLOAK_ADMIN_PASSWORD=
